{
    "extends": "../core/tsconfig.json",
    "compilerOptions": {
        "baseUrl": ".",
        "rootDir": "..",
        "paths": {
            "~/tinycld/contacts/*": ["./tinycld/contacts/*"],
            "@tinycld/core/*": ["../core/tinycld/core/*"],
            "@tinycld/*": ["../core/packages/@tinycld/*"],
            "~/*": ["../core/*"]
        },
        "noEmit": true
    },
    "include": ["**/*.ts", "**/*.tsx", "../core/**/*.d.ts", "../core/expo-env.d.ts", "../core/.expo/types/**/*.ts"],
    "exclude": ["node_modules", "server", "pb-migrations", "tests/**/*.spec.ts"]
}
